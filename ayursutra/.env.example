# ⚠️ WARNING: Replace ALL placeholder values below before deploying!

# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database Configuration (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ayursutra

# JWT Configuration
JWT_SECRET_KEY=change_this_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_this_to_a_random_64_char_string
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
